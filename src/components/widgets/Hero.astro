---
import { themeConfig } from '@/config'
import { getEntry } from 'astro:content'
import { render } from 'astro:content'

const { author, role, tagline, social } = themeConfig.site

const aboutEntry = await getEntry('about', 'about')
const hasAboutContent = aboutEntry?.body
  ? aboutEntry.body.replace(/<!--[\s\S]*?-->/g, '').trim().length > 0
  : false
const { Content } = hasAboutContent && aboutEntry ? await render(aboutEntry) : { Content: null }

const socialLinks = [
  social.email && { label: 'Email', href: `mailto:${social.email}` },
  social.github && { label: 'GitHub', href: social.github },
  social.linkedin && { label: 'LinkedIn', href: social.linkedin },
  social.x && { label: 'X', href: social.x }
].filter(Boolean) as { label: string; href: string }[]
---

<section class="hero">
  <h1 class="name">{author}</h1>
  {role && <p class="role">{role}</p>}
  {tagline && <p class="tagline">{tagline}</p>}
  {
    socialLinks.length > 0 && (
      <div class="social">
        {
          socialLinks.map((link) => (
            <a href={link.href} target={link.href.startsWith('mailto:') ? undefined : '_blank'} rel="noopener noreferrer">
              {link.label}
            </a>
          ))
        }
      </div>
    )
  }
  {
    hasAboutContent && Content && (
      <div class="about prose">
        <Content />
      </div>
    )
  }
</section>

<style>
  .hero {
    margin-bottom: 2.5rem;
  }

  .name {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .role {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
  }

  .tagline {
    margin: 0.75rem 0 0;
    line-height: 1.6;
  }

  .social {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1rem;
  }

  .social a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--font-size-s);
    border-bottom: 1px solid var(--border);
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .social a:hover {
      opacity: 0.6;
    }
  }

  .about {
    margin-top: 1.25rem;
  }
</style>

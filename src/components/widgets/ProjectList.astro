---
import type { ProjectListProps } from '@/types'
import TagList from '@/components/ui/TagList.astro'

const { projects } = Astro.props as ProjectListProps
---

<ul>
  {
    projects.map((project) => (
      <li>
        <a href={`/projects/${project.id}/`} class="project-link">
          <article class="project-item">
            {
              project.data.image && (
                <figure class="thumbnail">
                  <img src={project.data.image} alt="" loading="lazy" decoding="async" />
                </figure>
              )
            }
            <div class="project-body">
              <div class="project-header">
                <h2 class="title">{project.data.title}</h2>
                <div class="links">
                  {project.data.url && <span class="link">Live</span>}
                  {project.data.repo && <span class="link">Source</span>}
                </div>
              </div>
              <p class="description">{project.data.description}</p>
              <TagList tags={project.data.tags} basePath="/projects/tags" />
            </div>
          </article>
        </a>
      </li>
    ))
  }
</ul>
<div class="placeholder"></div>

<style>
  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .project-link {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover .project-link {
      opacity: 0.4;
    }

    ul:hover .project-link:hover {
      opacity: 1;
    }
  }

  .project-item {
    margin: 0;
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .thumbnail {
    margin: 0;
    flex-shrink: 0;
    width: 7rem;
  }

  .thumbnail img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
  }

  .project-body {
    flex: 1;
    min-width: 0;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .title {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .link {
    color: var(--text-tertiary);
    font-size: var(--font-size-s);
  }

  .description {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .tags {
    margin: 0.5rem 0 0;
    color: var(--text-tertiary);
    font-size: var(--font-size-s);
    letter-spacing: var(--spacing-s);
  }

  .project-body :global(.tags) {
    margin-top: 0.5rem;
  }

  .placeholder {
    height: 3rem;
  }

  @media (max-width: 32rem) {
    .project-item {
      flex-direction: column;
    }

    .thumbnail {
      width: 100%;
    }
  }
</style>

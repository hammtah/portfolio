---
import type { ProjectListProps } from '@/types'
import TagList from '@/components/ui/TagList.astro'

const { projects } = Astro.props as ProjectListProps
---

<ul>
  {
    projects.map((project) => (
      <li>
        <a href={`/projects/${project.id}/`} class="project-link">
          <article class="project-item">
            {
              project.data.image && (
                <figure class="thumbnail">
                  <img src={project.data.image} alt="" loading="lazy" decoding="async" />
                </figure>
              )
            }
            <div class="project-body">
              <div class="project-header">
                <h2 class="title">{project.data.title}</h2>
                <div class="links">
                  {project.data.url && <span class="link">Live</span>}
                  {project.data.repo && <span class="link">Source</span>}
                </div>
              </div>
              <p class="description">{project.data.description}</p>
              <TagList tags={project.data.tags} basePath="/projects/tags" />
            </div>
          </article>
        </a>
      </li>
    ))
  }
</ul>
<div class="placeholder"></div>

<style>
  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-link {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
  }

  .project-item {
    margin: 0;
    display: grid;
    grid-template-columns: 11rem 1fr;
    gap: 1.5rem;
    align-items: start;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    transition:
      border-color 0.15s ease-out,
      box-shadow 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-link:hover .project-item {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent-muted);
    }
  }

  .thumbnail {
    margin: 0;
    height: 100%;
    min-height: 7rem;
    background-color: var(--code-bg);
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    min-height: 7rem;
    object-fit: cover;
    display: block;
  }

  .project-body {
    padding: 1.125rem 1.125rem 1.125rem 0;
    min-width: 0;
  }

  .project-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .title {
    margin: 0;
    font-size: var(--font-size-l);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
  }

  .links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .link {
    color: var(--accent);
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-bold);
  }

  .description {
    margin: 0.5rem 0 0;
    color: var(--text-secondary);
    line-height: 1.55;
  }

  .project-body :global(.tags) {
    margin-top: 0.5rem;
  }

  .placeholder {
    height: 2rem;
  }

  @media (max-width: 40rem) {
    .project-item {
      grid-template-columns: 1fr;
    }

    .thumbnail img {
      aspect-ratio: 16 / 9;
      min-height: auto;
    }

    .project-body {
      padding: 0 1.125rem 1.125rem;
    }
  }
</style>

---
import type { ProjectListProps } from '@/types'
import TagList from '@/components/ui/TagList.astro'

const { projects } = Astro.props as ProjectListProps
---

{
  projects.length > 0 && (
    <section class="featured">
      <div class="featured-header">
        <h2>Featured projects</h2>
        <a href="/projects/" class="view-all">
          View all
        </a>
      </div>
      <ul>
        {
          projects.map((project) => (
            <li>
              <a href={`/projects/${project.id}/`} class="project-link">
                <article class="project-card">
                  {
                    project.data.image && (
                      <figure class="thumbnail">
                        <img src={project.data.image} alt="" loading="lazy" decoding="async" />
                      </figure>
                    )
                  }
                  <div class="project-body">
                    <h3 class="title">{project.data.title}</h3>
                    <p class="description">{project.data.description}</p>
                    <TagList tags={project.data.tags} basePath="/projects/tags" />
                  </div>
                </article>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  )
}

<style>
  .featured {
    margin-bottom: 2.5rem;
  }

  .featured-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .featured-header h2 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .view-all {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--font-size-s);
    transition: color 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .view-all:hover {
      color: var(--text-primary);
    }
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-link {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    transition: opacity 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    ul:hover .project-link {
      opacity: 0.4;
    }

    ul:hover .project-link:hover {
      opacity: 1;
    }
  }

  .project-card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .thumbnail {
    margin: 0;
    flex-shrink: 0;
    width: 5.5rem;
  }

  .thumbnail img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
  }

  .project-body {
    flex: 1;
    min-width: 0;
  }

  .title {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .description {
    margin: 0.25rem 0 0;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .tags {
    margin: 0.375rem 0 0;
    color: var(--text-tertiary);
    font-size: var(--font-size-s);
    letter-spacing: var(--spacing-s);
  }

  .project-body :global(.tags) {
    margin-top: 0.375rem;
  }
</style>

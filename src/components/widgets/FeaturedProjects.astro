---
import type { ProjectListProps } from '@/types'
import TagList from '@/components/ui/TagList.astro'

const { projects } = Astro.props as ProjectListProps
---

{
  projects.length > 0 && (
    <section class="featured">
      <div class="section-header">
        <h2 class="section-title">Featured projects</h2>
        <a href="/projects/" class="section-link">
          View all →
        </a>
      </div>
      <ul>
        {
          projects.map((project) => (
            <li>
              <a href={`/projects/${project.id}/`} class="project-link">
                <article class="project-card">
                  {
                    project.data.image && (
                      <figure class="thumbnail">
                        <img src={project.data.image} alt="" loading="lazy" decoding="async" />
                      </figure>
                    )
                  }
                  <div class="project-body">
                    <h3 class="title">{project.data.title}</h3>
                    <p class="description">{project.data.description}</p>
                    <TagList tags={project.data.tags} basePath="/projects/tags" />
                  </div>
                </article>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  )
}

<style>
  .featured {
    margin-bottom: 3rem;
  }

  ul {
    padding: 0;
    margin: 0;
    list-style-type: none;
    display: grid;
    gap: 1.25rem;
  }

  .project-link {
    color: var(--text-primary);
    display: block;
    text-decoration: none;
    height: 100%;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    overflow: hidden;
    background-color: var(--bg);
    transition:
      border-color 0.15s ease-out,
      box-shadow 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .project-link:hover .project-card {
      border-color: var(--accent);
      box-shadow: 0 0 0 1px var(--accent-muted);
    }
  }

  .thumbnail {
    margin: 0;
    aspect-ratio: 16 / 9;
    background-color: var(--code-bg);
    border-bottom: 1px solid var(--border);
  }

  .thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-body {
    padding: 1rem 1.125rem 1.125rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .title {
    margin: 0;
    font-size: var(--font-size-l);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
  }

  .description {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: var(--font-size-s);
    flex: 1;
  }

  .project-body :global(.tags) {
    margin-top: 0.25rem;
  }

  @media (min-width: 36rem) {
    ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

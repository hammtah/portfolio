---
import { resume } from '@/data/resume'

interface Props {
  showHeading?: boolean
  compact?: boolean
}

const { showHeading = true, compact = false } = Astro.props

const allSkills = resume.skills.flatMap((group) => group.items)
---

<section class:list={['skills', { compact }]}>
  {showHeading && <h2 class="section-title">Skills</h2>}
  {
    compact ? (
      <ul class="chip-list">
        {allSkills.map((skill) => (
          <li class="skill-chip">{skill}</li>
        ))}
      </ul>
    ) : (
      <div class="skill-groups">
        {
          resume.skills.map((group) => (
            <div class="skill-group">
              <h3 class="group-name">{group.name}</h3>
              <ul class="chip-list">
                {group.items.map((skill) => (
                  <li class="skill-chip">{skill}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    )
  }
</section>

<style>
  .skills {
    margin-bottom: 3rem;
  }

  .skills h2 {
    margin: 0 0 1rem;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .group-name {
    margin: 0 0 0.5rem;
    font-size: var(--font-size-s);
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .compact h2 {
    margin-bottom: 0.75rem;
  }
</style>

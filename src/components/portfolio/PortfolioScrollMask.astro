<div class="portfolio-scroll-mask" aria-hidden="true">
  <div class="portfolio-scroll-mask__blur"></div>
  <div class="portfolio-scroll-mask__background"></div>
</div>

<script>
  let mask: HTMLElement | null = null
  let nav: HTMLElement | null = null
  let ticking = false
  let isMobileSafariBrowser = false

  function isMobileSafari(): boolean {
    if (typeof window === 'undefined') return false

    const ua = navigator.userAgent
    const platform = navigator.platform

    const isIOSDevice = /iP(ad|hone|od)/.test(ua) || (platform === 'MacIntel' && navigator.maxTouchPoints > 1)

    if (!isIOSDevice) return false

    const isSafari = /Safari\//.test(ua) && !/(CriOS|FxiOS|EdgiOS|OPiOS|DuckDuckGo)/.test(ua)
    if (!isSafari) return false

    const isMobileLike =
      window.matchMedia?.('(pointer: coarse)').matches || window.matchMedia?.('(max-width: 768px)').matches

    return Boolean(isMobileLike)
  }

  function updateScrollEffects() {
    if (isMobileSafariBrowser) return

    if (!mask) mask = document.querySelector('.portfolio-scroll-mask')
    if (!nav) nav = document.getElementById('portfolio-nav')
    if (!mask) return

    const threshold = 16
    const scrolled = window.scrollY >= threshold

    mask.style.opacity = scrolled ? '1' : '0'
    nav?.classList.toggle('is-scrolled', scrolled)
  }

  function onScroll() {
    if (ticking) return
    ticking = true
    requestAnimationFrame(() => {
      updateScrollEffects()
      ticking = false
    })
  }

  function initScrollMask() {
    isMobileSafariBrowser = isMobileSafari()
    mask = document.querySelector('.portfolio-scroll-mask')
    nav = document.getElementById('portfolio-nav')

    if (isMobileSafariBrowser && mask) {
      mask.style.display = 'none'
      return
    }

    updateScrollEffects()
  }

  document.addEventListener('astro:page-load', initScrollMask)
  window.addEventListener('scroll', onScroll, { passive: true })

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollMask, { once: true })
  } else {
    initScrollMask()
  }
</script>

<style is:global>
  .portfolio-scroll-mask {
    --scroll-mask-gradient: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.738) 19%,
      rgba(0, 0, 0, 0.541) 34%,
      rgba(0, 0, 0, 0.382) 47%,
      rgba(0, 0, 0, 0.278) 56.5%,
      rgba(0, 0, 0, 0.194) 65%,
      rgba(0, 0, 0, 0.126) 73%,
      rgba(0, 0, 0, 0.075) 80.2%,
      rgba(0, 0, 0, 0.042) 86.1%,
      rgba(0, 0, 0, 0.021) 91%,
      rgba(0, 0, 0, 0.008) 95.2%,
      rgba(0, 0, 0, 0.002) 98.2%,
      transparent 100%
    );
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 5rem;
    z-index: 49;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease-out;
  }

  .portfolio-scroll-mask__blur,
  .portfolio-scroll-mask__background {
    position: absolute;
    inset: 0;
    mask-image: var(--scroll-mask-gradient);
    -webkit-mask-image: var(--scroll-mask-gradient);
  }

  .portfolio-scroll-mask__blur {
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .portfolio-scroll-mask__background {
    background-color: var(--color-background);
    transition: background-color 0.2s ease-out;
  }

  @media (min-width: 768px) {
    .portfolio-scroll-mask {
      height: 6rem;
    }
  }
</style>

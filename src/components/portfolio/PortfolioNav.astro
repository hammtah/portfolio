---
import { themeConfig } from '@/config'

interface Props {
  currentPath?: string
}

const { currentPath = Astro.url.pathname } = Astro.props

const showThemeToggle = themeConfig.general.themeToggle

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'CV', href: '/cv/' }
]

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === ''
  if (href === '/blog/') return currentPath.startsWith('/blog')
  return currentPath.startsWith(href)
}
---

<nav id="portfolio-nav" class="portfolio-nav bg-background w-full top-0 border-b border-outline-variant z-50 sticky">
  <div class="flex justify-between items-center max-w-[800px] mx-auto px-gutter py-stack-md">
    <a
      class="font-headline-md text-headline-md font-bold text-primary tracking-tight"
      href="/"
    >
      {themeConfig.site.title}
    </a>

    <div class="flex items-center gap-stack-md">
      <div class="hidden md:flex gap-stack-md items-center">
        {
          navLinks.map((item) => (
            <a
              href={item.href}
              data-nav-link
              class:list={[
                'font-label-md text-label-md transition-colors',
                isActive(item.href)
                  ? 'text-primary border-b-2 border-primary pb-1'
                  : 'text-secondary hover:text-primary'
              ]}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      {
        showThemeToggle && (
          <button
            type="button"
            data-theme-toggle
            class="theme-toggle-btn text-secondary hover:text-primary transition-colors inline-flex items-center"
            aria-label="Toggle color theme"
          >
            <span class="material-symbols-outlined text-[20px] theme-icon theme-icon-light">dark_mode</span>
            <span class="material-symbols-outlined text-[20px] theme-icon theme-icon-dark">light_mode</span>
          </button>
        )
      }

      <button
        type="button"
        class="md:hidden text-primary inline-flex items-center"
        aria-label="Open menu"
        aria-expanded="false"
        id="mobile-nav-toggle"
      >
        <span class="material-symbols-outlined">menu</span>
      </button>
    </div>
  </div>

  <div class="hidden border-t border-outline-variant" id="mobile-nav-panel">
    <div class="flex flex-col max-w-[800px] mx-auto px-gutter py-stack-sm gap-stack-sm">
      {
        navLinks.map((item) => (
          <a
            href={item.href}
            data-nav-link
            class:list={[
              'font-label-md text-label-md py-2 transition-colors',
              isActive(item.href) ? 'text-primary font-bold' : 'text-secondary hover:text-primary'
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  const ACTIVE_CLASS = ['text-primary', 'border-b-2', 'border-primary', 'pb-1']
  const INACTIVE_CLASS = ['text-secondary', 'hover:text-primary', 'transition-colors']

  function isNavActive(href: string, path: string): boolean {
    const section = document.body.dataset.navSection
    if (section === 'blog' && href === '/blog/') return true
    if (href === '/') return path === '/' || path === ''
    if (href === '/blog/') return path.startsWith('/blog')
    return path.startsWith(href)
  }

  function updateNavActiveState() {
    const path = window.location.pathname
    const links = document.querySelectorAll<HTMLAnchorElement>('#portfolio-nav [data-nav-link]')

    links.forEach((link) => {
      const href = link.getAttribute('href') ?? ''
      const active = isNavActive(href, path)
      const isDesktopLink = link.closest('#mobile-nav-panel') === null

      if (isDesktopLink) {
        link.classList.remove(...ACTIVE_CLASS, ...INACTIVE_CLASS)
        if (active) {
          link.classList.add(...ACTIVE_CLASS)
          link.setAttribute('aria-current', 'page')
        } else {
          link.classList.add(...INACTIVE_CLASS)
          link.removeAttribute('aria-current')
        }
        return
      }

      link.classList.remove('text-primary', 'font-bold', 'text-secondary', 'hover:text-primary')
      if (active) {
        link.classList.add('text-primary', 'font-bold')
      } else {
        link.classList.add('text-secondary', 'hover:text-primary')
      }
    })
  }

  const toggle = document.getElementById('mobile-nav-toggle')
  const panel = document.getElementById('mobile-nav-panel')

  toggle?.addEventListener('click', () => {
    const isOpen = !panel?.classList.contains('hidden')
    panel?.classList.toggle('hidden', isOpen)
    toggle.setAttribute('aria-expanded', String(!isOpen))
    toggle.querySelector('.material-symbols-outlined')!.textContent = isOpen ? 'menu' : 'close'
  })

  function bindThemeToggles() {
    const buttons = document.querySelectorAll<HTMLElement>('[data-theme-toggle]')
    buttons.forEach((button) => {
      if (button.dataset.themeBound) return
      button.dataset.themeBound = 'true'
      button.addEventListener('click', (event) => {
        event.preventDefault()
        ;(window as unknown as { ThemeManager?: { toggle: () => void } }).ThemeManager?.toggle()
      })
    })
  }

  document.addEventListener('astro:page-load', () => {
    updateNavActiveState()
    bindThemeToggles()
  })
  updateNavActiveState()
  bindThemeToggles()
</script>

<style is:global>
  #portfolio-nav {
    transition:
      background-color 0.2s ease-out,
      backdrop-filter 0.2s ease-out,
      -webkit-backdrop-filter 0.2s ease-out;
  }

  #portfolio-nav.is-scrolled {
    background-color: color-mix(in srgb, var(--color-background) 72%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .theme-toggle-btn {
    cursor: pointer;
  }

  .theme-icon-dark {
    display: none;
  }

  html.dark .theme-icon-light {
    display: none;
  }

  html.dark .theme-icon-dark {
    display: inline-block;
  }
</style>

---
import IndexLayout from '@/layouts/IndexLayout.astro'
import Skills from '@/components/widgets/Skills.astro'
import { themeConfig } from '@/config'
import { resume } from '@/data/resume'
import '@/styles/cv-print.css'
---

<IndexLayout title={`CV — ${themeConfig.site.title}`} description={`Resume for ${themeConfig.site.author}`}>
  <div class="cv-page">
    <div class="cv-actions">
      <button type="button" id="download-cv" class="btn btn-primary">Download PDF</button>
    </div>

    <header class="cv-header">
      <h1>{themeConfig.site.author}</h1>
      {themeConfig.site.role && <p class="role">{themeConfig.site.role}</p>}
      <div class="contact font-features">
        {
          themeConfig.site.social.email && (
            <a href={`mailto:${themeConfig.site.social.email}`}>{themeConfig.site.social.email}</a>
          )
        }
        {themeConfig.site.social.github && <a href={themeConfig.site.social.github}>GitHub</a>}
        {themeConfig.site.social.linkedin && <a href={themeConfig.site.social.linkedin}>LinkedIn</a>}
      </div>
    </header>

    <section class="cv-section">
      <h2>Summary</h2>
      <p>{resume.summary}</p>
    </section>

    <section class="cv-section">
      <h2>Experience</h2>
      {
        resume.experience.map((entry) => (
          <article class="entry">
            <div class="entry-header">
              <div>
                <h3>{entry.role}</h3>
                <p class="meta">
                  {entry.company}
                  {entry.location && ` · ${entry.location}`}
                </p>
              </div>
              <p class="dates font-features">
                {entry.start} – {entry.end}
              </p>
            </div>
            <ul>
              {entry.highlights.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </section>

    <section class="cv-section">
      <h2>Education</h2>
      {
        resume.education.map((entry) => (
          <article class="entry">
            <div class="entry-header">
              <div>
                <h3>{entry.degree}</h3>
                <p class="meta">
                  {entry.school}
                  {entry.location && ` · ${entry.location}`}
                </p>
              </div>
              <p class="dates font-features">
                {entry.start} – {entry.end}
              </p>
            </div>
            {
              entry.details && (
                <ul>
                  {entry.details.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )
            }
          </article>
        ))
      }
    </section>

    <section class="cv-section">
      <Skills showHeading={true} />
    </section>
  </div>
</IndexLayout>

<script>
  const button = document.getElementById('download-cv')
  button?.addEventListener('click', () => {
    window.print()
  })
</script>

<style>
  .cv-page {
    padding-bottom: 2rem;
  }

  .cv-actions {
    margin-bottom: 2rem;
  }

  .cv-header h1 {
    margin: 0;
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-semibold);
    line-height: 1.2;
  }

  .role {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.75rem;
    font-size: var(--font-size-s);
  }

  .contact a {
    color: var(--accent);
    text-decoration: none;
    font-weight: var(--font-weight-bold);
  }

  .cv-section {
    margin-top: 2rem;
  }

  .cv-section h2 {
    margin: 0 0 1rem;
    font-size: var(--font-size-l);
    font-weight: var(--font-weight-semibold);
  }

  .cv-section > p {
    margin: 0;
    line-height: 1.6;
    color: var(--text-secondary);
  }

  .entry {
    margin-bottom: 1.5rem;
  }

  .entry:last-child {
    margin-bottom: 0;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .entry h3 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .meta {
    margin: 0.25rem 0 0;
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .dates {
    margin: 0;
    color: var(--text-tertiary);
    font-size: var(--font-size-s);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry ul {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .entry li + li {
    margin-top: 0.25rem;
  }

  @media (max-width: 32rem) {
    .entry-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>

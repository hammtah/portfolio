---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import { themeConfig } from '@/config'

const { author, social, availability } = themeConfig.site

const connectLinks = [
  social.email && { label: 'Email', href: `mailto:${social.email}`, icon: 'mail' },
  social.linkedin && { label: 'LinkedIn', href: social.linkedin, icon: 'link' },
  social.github && { label: 'GitHub', href: social.github, icon: 'code' },
  social.x && { label: 'X', href: social.x, icon: 'tag' }
].filter(Boolean) as { label: string; href: string; icon: string }[]

const statusMeta = [availability?.timezone, availability?.responseTime && `replies in ${availability.responseTime}`]
  .filter(Boolean)
  .join(' · ')
---

<PortfolioLayout title={`Contact — ${themeConfig.site.title}`} description={`Contact ${author}`}>
  <div class="max-w-xl mx-auto w-full flex flex-col gap-section-gap-md">
    <div class="flex flex-col gap-stack-sm">
      <span class="font-label-sm text-label-sm text-secondary uppercase">Contact</span>
      <h1 class="font-display-mobile md:font-display text-display-mobile md:text-display text-primary">
        Get in touch
      </h1>
      <p class="font-body-lg text-body-lg text-secondary">
        I'm currently open to freelance and part-time work. If you've got a project you'd like help with, I'd love to hear about it.
      </p>
    </div>

    {
      availability && (
        <div class="flex items-center gap-2 border border-outline-variant px-4 py-3">
          <span
            class:list={['status-dot', availability.available ? 'status-available' : 'status-unavailable']}
          />
          <span class="font-label-md text-label-md text-primary">
            {availability.available ? availability.label ?? 'Available for new projects' : 'Not currently available'}
          </span>
          {statusMeta && <span class="font-label-sm text-label-sm text-outline ml-auto">{statusMeta}</span>}
        </div>
      )
    }

    <form class="flex flex-col gap-stack-md" data-contact-form>
      <div class="flex flex-col gap-1">
        <label class="font-label-sm text-label-sm text-secondary uppercase" for="name">Name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          placeholder="Jane Doe"
          class="contact-input py-2 px-0 w-full font-body-md text-body-md text-primary placeholder:text-outline-variant bg-transparent"
        />
      </div>
      <div class="flex flex-col gap-1">
        <label class="font-label-sm text-label-sm text-secondary uppercase" for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          placeholder="jane@example.com"
          class="contact-input py-2 px-0 w-full font-body-md text-body-md text-primary placeholder:text-outline-variant bg-transparent"
        />
      </div>
      <div class="flex flex-col gap-1">
        <label class="font-label-sm text-label-sm text-secondary uppercase" for="message">Message</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          placeholder={`Hello ${author}, I'd like to talk about...`}
          class="contact-input py-2 px-0 w-full font-body-md text-body-md text-primary placeholder:text-outline-variant bg-transparent resize-none"
        ></textarea>
      </div>
      <button
        type="submit"
        class="border border-primary bg-surface-container-lowest text-primary font-label-md text-label-md py-3 px-6 hover:bg-primary hover:text-on-primary transition-colors"
      >
        Send message
      </button>
      <p class="text-label-sm font-label-sm text-secondary hidden" data-contact-status></p>
    </form>

    {
      connectLinks.length > 0 && (
        <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 pt-stack-md border-t border-outline-variant">
          {connectLinks.map((link) => (
            <a
              class="flex items-center gap-2 group font-label-md text-label-md text-secondary hover:text-primary transition-colors"
              href={link.href}
              target={link.href.startsWith('mailto:') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto:') ? undefined : 'noopener noreferrer'}
            >
              <span class="material-symbols-outlined text-[18px]">{link.icon}</span>
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</PortfolioLayout>

<style>
  .contact-input {
    border: none;
    border-bottom: 1px solid var(--color-outline-variant);
    border-radius: 0;
  }

  .contact-input:focus {
    outline: none;
    border-bottom: 2px solid var(--color-primary);
    box-shadow: none;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 9999px;
    flex-shrink: 0;
  }

  .status-available {
    background: #3b6d11;
  }

  .status-unavailable {
    background: var(--color-error);
  }

  html.dark .status-available {
    background: #97c459;
  }
</style>

<script is:inline define:vars={{ siteEmail: themeConfig.site.social.email }}>
  function initContactForm() {
    const form = document.querySelector('[data-contact-form]')
    const status = document.querySelector('[data-contact-status]')
    if (!form || form.dataset.contactInit) return
    form.dataset.contactInit = '1'

    form.addEventListener('submit', (e) => {
      e.preventDefault()
      const data = new FormData(form)
      const name = String(data.get('name') || '')
      const email = String(data.get('email') || '')
      const message = String(data.get('message') || '')

      const subject = encodeURIComponent(`Message from ${name} via portfolio site`)
      const body = encodeURIComponent(`${message}\n\n— ${name} (${email})`)
      window.location.href = `mailto:${siteEmail}?subject=${subject}&body=${body}`

      if (status) {
        status.textContent = 'Opening your email client…'
        status.classList.remove('hidden')
      }
    })
  }

  document.addEventListener('astro:page-load', initContactForm)
</script>
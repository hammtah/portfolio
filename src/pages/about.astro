---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import { themeConfig } from '@/config'
import { resume } from '@/data/resume'
import { getEntry, render } from 'astro:content'

const { author, role, cvUrl, tagline } = themeConfig.site

const aboutEntry = await getEntry('about', 'about')
const { Content } = aboutEntry ? await render(aboutEntry) : { Content: null }
---

<PortfolioLayout title={`About — ${themeConfig.site.title}`} description={`About ${author}`}>
  <!-- Intro header -->
  <section class="">
    <h1 class="font-display-mobile md:font-display text-display-mobile md:text-display text-primary mb-stack-sm">
      {author}.
      <span class="text-secondary font-headline-md text-headline-md md:font-headline-lg md:text-headline-lg block mt-2">
        {role}
      </span>
    </h1>
    {tagline && <p class="font-body-lg text-body-lg text-secondary max-w-2xl">{tagline}</p>}
    {
    cvUrl && (
      <a
        href={cvUrl}
        download
        class="inline-flex items-center justify-center gap-2 border border-primary bg-surface-container-lowest text-primary px-8 py-3 mt-3 font-label-md text-label-md hover:bg-primary hover:text-on-primary transition-colors"
      >
        <span class="material-symbols-outlined text-[18px]">download</span>
        Download CV (PDF)
      </a>
    )
    }
  </section>

  <!-- Photo -->
  <section class="mb-section-gap-md">
    <img
      src="/images/about.jpg"
      alt={author}
      class="w-full h-[300px] sm:max-w-[600px] sm:h-[500px] object-cover border border-outline-variant rounded-sm"
      loading="eager"
      decoding="async"
    />
  </section>

  <!-- Narrative bio -->
  <section class="mb-section-gap-md grid grid-cols-1 md:grid-cols-3 gap-stack-md">
    <div class="md:col-span-1">
      <h2 class="font-headline-md text-headline-md text-primary border-b border-outline-variant pb-2 inline-block">
        The journey
      </h2>
    </div>
    <div class="md:col-span-2 space-y-6">
      {
        Content ? (
          <div class="journal-prose prose">
            <Content />
          </div>
        ) : (
          <div class="border border-dashed border-outline-variant p-stack-md font-body-md text-body-md text-outline">
            {/* Add your narrative bio here — 2–3 paragraphs on how you got into software, what problems you
            enjoy, and what you're focused on now. */}
          </div>
        )
      }
    </div>
  </section>

  <!-- Current focus & personal touch -->
  <section class="mb-section-gap-md grid grid-cols-1 md:grid-cols-2 gap-stack-md">
    <div class="border border-outline-variant p-8 bg-surface-container-low">
      <h3 class="font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-4">Current focus</h3>
      <p class="font-body-md text-body-md text-outline"> Designing and implementing a distributed key-value store in Go, evolving from a single-node Redis clone into a DynamoDB-inspired distributed architecture.</p>
    </div>

    <div class="border border-outline-variant p-8">
      <h3 class="font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-4">
        Perspective &amp; interests
      </h3>
      <p class="font-body-md text-body-md text-outline">
        <!-- Add a short list here — opinions on software, a pet peeve, a non-work interest. -->
        <ul style="list-style-type: none;">
          <li>- Complexity bad as grug says. </li>
          <li>- Crafting Interpreters &gt; The Dragon Book.</li>
          <li>- Loves simplicity and Go. </li>
        </ul>
      </p>
    </div>
  </section>

  <!-- Skills snapshot -->
  {
    resume.skills?.length > 0 && (
      <section class="mb-section-gap-md">
        <h2 class="font-headline-md text-headline-md text-primary border-b border-outline-variant pb-2 mb-stack-md inline-block">
          Toolkit
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {resume.skills.map((group) => (
            <div>
              <h4 class="font-label-sm text-label-sm text-secondary mb-3 uppercase tracking-widest">
                {group.name}
              </h4>
              <ul class="font-label-md text-label-md text-on-surface space-y-2">
                {group.items.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- Closing CTA -->
  <section class="text-center py-section-gap-md border-t border-outline-variant">
    <h2 class="font-headline-lg text-headline-lg text-primary mb-stack-md">Ready to build?</h2>
    <div class="flex flex-col sm:flex-row justify-center items-center gap-6">
      {
        cvUrl && (
          <a
            href={cvUrl}
            download
            class="inline-flex items-center justify-center gap-2 border border-primary bg-surface-container-lowest text-primary px-8 py-3 font-label-md text-label-md hover:bg-primary hover:text-on-primary transition-colors"
          >
            <span class="material-symbols-outlined text-[18px]">download</span>
            Download CV (PDF)
          </a>
        )
      }
      <a href="/contact/" class="font-label-md text-label-md text-secondary hover:text-primary transition-colors">
        Get in touch
      </a>
    </div>
  </section>
</PortfolioLayout>
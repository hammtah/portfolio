---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import JournalArchive from '@/components/portfolio/JournalArchive.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'
import { getUniqueTags } from '@/utils/tags'

export async function getStaticPaths() {
  const posts = await getSortedFilteredPosts()
  const tags = getUniqueTags(posts)

  return tags.map(({ tag, slug }) => ({
    params: { tag: slug },
    props: { tag }
  }))
}

const { tag } = Astro.props
const posts = (await getSortedFilteredPosts()).filter((post) => post.data.tags.includes(tag))
---

<PortfolioLayout
  title={`${tag} — Journal — ${themeConfig.site.title}`}
  description={`Posts tagged ${tag}`}
  mainClass="py-section-gap-md w-full pb-section-gap-lg"
>
  <JournalArchive posts={posts} activeTag={tag} />
</PortfolioLayout>

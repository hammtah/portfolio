---
import IndexLayout from '@/layouts/IndexLayout.astro'
import PostList from '@/components/widgets/PostList.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'
import { getUniqueTags } from '@/utils/tags'

export async function getStaticPaths() {
  const posts = await getSortedFilteredPosts()
  const tags = getUniqueTags(posts)

  return tags.map(({ tag, slug }) => ({
    params: { tag: slug },
    props: { tag }
  }))
}

const { tag } = Astro.props
const posts = (await getSortedFilteredPosts()).filter((post) => post.data.tags.includes(tag))
---

<IndexLayout title={`${tag} — Blog — ${themeConfig.site.title}`} description={`Posts tagged ${tag}`}>
  <header class="page-header">
    <h1>{tag}</h1>
    <p class="subtitle">
      <a href="/blog/">← All posts</a>
    </p>
  </header>
  <PostList posts={posts} />
</IndexLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .subtitle {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .subtitle a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .subtitle a:hover {
      color: var(--text-primary);
    }
  }
</style>

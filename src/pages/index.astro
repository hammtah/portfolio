---
import IndexLayout from '@/layouts/IndexLayout.astro'
import Hero from '@/components/widgets/Hero.astro'
import FeaturedProjects from '@/components/widgets/FeaturedProjects.astro'
import Skills from '@/components/widgets/Skills.astro'
import PostList from '@/components/widgets/PostList.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'
import { getFeaturedProjects } from '@/utils/projects'

const posts = (await getSortedFilteredPosts()).slice(0, 5)
const featuredProjects = await getFeaturedProjects()
---

<IndexLayout title={themeConfig.site.title} description={themeConfig.site.description}>
  <Hero />
  <FeaturedProjects projects={featuredProjects} />
  <Skills />
  <section class="recent-posts">
    <div class="section-header">
      <h2>Recent posts</h2>
      <a href="/blog/" class="view-all">View all</a>
    </div>
    <PostList posts={posts} />
  </section>
</IndexLayout>

<style>
  .recent-posts {
    margin-top: 0;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .view-all {
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--font-size-s);
    transition: color 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .view-all:hover {
      color: var(--text-primary);
    }
  }
</style>

---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import HomeHero from '@/components/portfolio/HomeHero.astro'
import FeaturedWork from '@/components/portfolio/FeaturedWork.astro'
import LatestThoughts from '@/components/portfolio/LatestThoughts.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'
import { getFeaturedProjects } from '@/utils/projects'

const posts = (await getSortedFilteredPosts()).slice(0, 3)
const featuredProjects = await getFeaturedProjects()
---

<PortfolioLayout title={themeConfig.site.title} description={themeConfig.site.description}>
  <HomeHero />
  <FeaturedWork projects={featuredProjects} />
  <LatestThoughts posts={posts} />
</PortfolioLayout>

---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import JournalArchive from '@/components/portfolio/JournalArchive.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'

const posts = await getSortedFilteredPosts()
---

<PortfolioLayout
  title={`Journal — ${themeConfig.site.title}`}
  description="Technical writing and notes"
  mainClass="py-section-gap-md w-full pb-section-gap-lg"
>
  <JournalArchive posts={posts} />
</PortfolioLayout>

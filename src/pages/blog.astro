---
import IndexLayout from '@/layouts/IndexLayout.astro'
import PostList from '@/components/widgets/PostList.astro'
import { themeConfig } from '@/config'
import { getSortedFilteredPosts } from '@/utils/draft'

const posts = await getSortedFilteredPosts()
---

<IndexLayout title={`Blog — ${themeConfig.site.title}`} description="Writing and notes">
  <header class="page-header">
    <h1>Blog</h1>
    <p class="subtitle">Thoughts, tutorials, and things I'm learning.</p>
  </header>
  <PostList posts={posts} />
</IndexLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .subtitle {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
  }
</style>

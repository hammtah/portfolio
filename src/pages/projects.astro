---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import ProjectsGrid from '@/components/portfolio/ProjectsGrid.astro'
import { themeConfig } from '@/config'
import { getSortedProjects } from '@/utils/projects'

const projects = await getSortedProjects()

const intro =
  'A selection of recent work, open-source contributions, and technical explorations focused on performance and architectural clarity.'
---

<PortfolioLayout
  title={`Projects — ${themeConfig.site.title}`}
  description="Selected projects and work"
  mainClass="py-section-gap-md w-full"
>
  <div class="mb-section-gap-md">
    <h1
      class="font-display-mobile text-display-mobile md:font-display md:text-display text-primary mb-stack-md"
    >
      Projects
    </h1>
    <p class="font-body-lg text-body-lg text-secondary">
      {intro}
    </p>
  </div>

  <ProjectsGrid projects={projects} />
</PortfolioLayout>

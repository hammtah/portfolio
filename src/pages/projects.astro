---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import ProjectsGrid from '@/components/portfolio/ProjectsGrid.astro'
import { themeConfig } from '@/config'
import { getSortedProjects } from '@/utils/projects'

const projects = await getSortedProjects()

const intro =
  "A working log of software projects — coursework, personal builds, and the occasional weekend experiment. Filter by stack below."
---

<PortfolioLayout
  title={`Projects — ${themeConfig.site.title}`}
  description="Selected projects and work"
  mainClass="py-section-gap-md w-full"
>
  <header class="pb-stack-md mb-stack-md border-b border-outline-variant">
    <p class="font-label-sm text-label-sm text-secondary uppercase tracking-widest mb-stack-sm">Projects</p>
    <h1
      class="font-display-mobile text-display-mobile md:font-display md:text-display text-primary mb-stack-sm"
    >
      Things I've built
    </h1>
    <p class="font-body-md text-body-md text-secondary max-w-[560px]">
      {intro}
    </p>
  </header>

  <ProjectsGrid projects={projects} totalCount={projects.length} />
</PortfolioLayout>

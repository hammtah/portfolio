---
import { type CollectionEntry, getCollection } from 'astro:content'
import PortfolioProjectLayout from '@/layouts/PortfolioProjectLayout.astro'
import { render } from 'astro:content'

export async function getStaticPaths() {
  const projects = await getCollection('projects')
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project
  }))
}

type Props = CollectionEntry<'projects'>

const project = Astro.props
const { Content, remarkPluginFrontmatter } = await render(project)
const contentFeatures = remarkPluginFrontmatter.contentFeatures || {}
---

<PortfolioProjectLayout {...project.data} contentFeatures={contentFeatures}>
  <Content />
</PortfolioProjectLayout>

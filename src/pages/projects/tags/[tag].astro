---
import IndexLayout from '@/layouts/IndexLayout.astro'
import ProjectList from '@/components/widgets/ProjectList.astro'
import { themeConfig } from '@/config'
import { getSortedProjects } from '@/utils/projects'
import { getUniqueTags } from '@/utils/tags'

export async function getStaticPaths() {
  const projects = await getSortedProjects()
  const tags = getUniqueTags(projects)

  return tags.map(({ tag, slug }) => ({
    params: { tag: slug },
    props: { tag }
  }))
}

const { tag } = Astro.props
const projects = (await getSortedProjects()).filter((project) => project.data.tags.includes(tag))
---

<IndexLayout title={`${tag} — Projects — ${themeConfig.site.title}`} description={`Projects tagged ${tag}`}>
  <header class="page-header">
    <h1>{tag}</h1>
    <p class="subtitle">
      <a href="/projects/">← All projects</a>
    </p>
  </header>
  <ProjectList projects={projects} />
</IndexLayout>

<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: inherit;
    font-weight: var(--font-weight-bold);
  }

  .subtitle {
    margin: 0.375rem 0 0;
    color: var(--text-secondary);
    font-size: var(--font-size-s);
  }

  .subtitle a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease-out;
  }

  @media (hover: hover) and (pointer: fine) {
    .subtitle a:hover {
      color: var(--text-primary);
    }
  }
</style>
